# --- Dependencies ---
node_modules/          # Ignore Node.js dependencies
venv/                  # Ignore Python virtual environments
.env                   # Ignore environment variables (sensitive data)

# --- Build Outputs ---
dist/                  # Ignore production builds
build/                 # Ignore build artifacts
*.exe                  # Ignore all executable files

# --- Logs ---
*.log                  # Ignore all log files
npm-debug.log*         # Ignore specific npm debug logs

# --- OS Specific Files ---
.DS_Store              # Ignore macOS system files
Thumbs.db              # Ignore Windows thumbnail caches

# --- IDE Settings ---
.vscode/               # Ignore Visual Studio Code settings
.idea/                 # Ignore IntelliJ IDEA settings
*.swp                  # Ignore Vim swap files